# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (Embeddings)
OPENAI_API_KEY=sk-your-openai-key

# OpenRouter (LLM - MiniMax M2.5)
OPENROUTER_API_KEY=your-openrouter-key

# Resend (Email)
RESEND_API_KEY=re_your-resend-key

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Telegram Bot (board notifications + remote approvals)
# 1. Create a bot with @BotFather → get the token
# 2. Add the bot to your board group/channel → get the chat ID (use @userinfobot)
# 3. After deploying, register the webhook: POST /api/telegram/webhook with registerTelegramWebhook()
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_WEBHOOK_SECRET=your-random-secret-string

# Paperclip board API key (used by Telegram bot to approve/reject tasks remotely)
# Generate a board-level API key in the Paperclip dashboard
PAPERCLIP_BOARD_API_KEY=your-paperclip-board-api-key
PAPERCLIP_COMPANY_ID=your-paperclip-company-id
PAPERCLIP_API_URL=http://127.0.0.1:3101
