# ──────────────────────────────────────────────────────────────
# MAI Legacy — Staging Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file and fill in values from your **staging** Supabase
# project and service accounts.  Never reuse production credentials.
#
# On the VPS: set these in /etc/mai-legacy/.env.staging
# or your deployment's environment configuration.
# ──────────────────────────────────────────────────────────────

# ── Supabase (STAGING project — separate from production) ─────
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# ── OpenAI (Embeddings) ──────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ── OpenRouter (LLM) ─────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-key

# ── Resend (Email — use test/staging domain) ─────────────────
RESEND_API_KEY=re_your-resend-key

# ── Sentry (separate staging project recommended) ────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=mai-legacy-staging
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ── PostHog Analytics (staging project or same with flag) ────
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-staging-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── App URL ──────────────────────────────────────────────────
# Set to the staging domain served by your VPS.
NEXT_PUBLIC_APP_URL=https://staging.usemai.com

# ── Stripe (TEST mode keys — never live keys in staging) ─────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-staging-stripe-key
STRIPE_SECRET_KEY=sk_test_your-staging-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-staging-webhook-secret
STRIPE_PRICE_ROOTS=price_your-staging-roots-price-id
STRIPE_PRICE_LEGACY=price_your-staging-legacy-price-id

# ── Telegram (optional in staging) ───────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
