{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "crons": [
    {
      "path": "/api/digest/send",
      "schedule": "0 20 * * 0"
    },
    {
      "path": "/api/drip/send",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/process-embedding-jobs",
      "schedule": "* * * * *"
    }
  ]
}
